@page "/"
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Logo BI — Self-Service BI Tasarımcısı</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-6">
    <!-- Üstte: Firma/Dönem ve Çıpa (Ana Kaynak) -->
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="int" 
                           Label="Firma" 
                           Value="@_selectedFirmNr" 
                           ValueChanged="OnFirmChanged"
                           Variant="Variant.Outlined" 
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="0" Disabled="true">Seçiniz...</MudSelectItem>
                    @foreach (var f in _catalogFirms)
                    {
                        <MudSelectItem Value="@f.FirmNr">@($"{f.FirmNr}-{f.FirmName}")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="int" 
                           Label="Dönem" 
                           Value="@_selectedPeriodNr" 
                           ValueChanged="OnPeriodChanged"
                           Variant="Variant.Outlined" 
                           Disabled="@(_selectedFirmNr <= 0 || !CurrentPeriods.Any())"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="0" Disabled="true">Seçiniz...</MudSelectItem>
                    @foreach (var p in CurrentPeriods)
                    {
                        <MudSelectItem Value="@p.PeriodNr">@($"{p.PeriodNr}-{p.Label}")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="int" 
                           Label="Çıpa (Ana Kaynak)" 
                           Value="@_selectedAnchorId" 
                           ValueChanged="OnAnchorChanged"
                           Variant="Variant.Outlined" 
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="0" Disabled="true">Seçiniz...</MudSelectItem>
                    @foreach (var source in _sources)
                    {
                        <MudSelectItem Value="@source.Id">@source.DisplayName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" Class="d-flex align-center justify-end gap-4 mt-2">
                <div class="d-flex align-center">
                    <MudText Typo="Typo.body2" Class="me-2 fw-bold" Color="Color.Primary">Görünüm:</MudText>
                    @if (IsKpiAllowed)
                    {
                        <MudToggleGroup T="string" Value="@_selectedView" ValueChanged="OnViewChanged" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary">
                            <MudToggleItem Value="@("Grid")" Text="Grid" />
                            <MudToggleItem Value="@("KPI")" Text="KPI" />
                        </MudToggleGroup>
                    }
                    else
                    {
                        <MudTooltip Text="KPI için tam 1 measure ve 0 boyut seçin." Placement="Placement.Top">
                            <div>
                                <MudToggleGroup T="string" Value="@("Grid")" Disabled="true" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary">
                                    <MudToggleItem Value="@("Grid")" Text="Grid" />
                                    <MudToggleItem Value="@("KPI")" Text="KPI" />
                                </MudToggleGroup>
                            </div>
                        </MudTooltip>
                    }
                </div>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           OnClick="OnPreviewClicked" 
                           Disabled="@(_selectedFirmNr <= 0 || _selectedPeriodNr <= 0 || _selectedAnchorId <= 0 || !_dropItems.Any(x => x.DropZone == "report-zone") || _isLoading)"
                           Class="px-6 py-2">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" Color="Color.Default" />
                        <span>Yükleniyor...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="me-1" />
                        <span>Önizle</span>
                    }
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Sürükle-Bırak Alanı -->
    <MudDropContainer T="DropItem" 
                      Items="@_dropItems" 
                      ItemsSelector="@((item, zone) => item.DropZone == zone)" 
                      ItemDropped="OnItemDropped" 
                      Class="d-flex flex-grow-1">
        <ChildContent>
            <MudGrid>
                <!-- Sol Panel: Alan Listesi (kaynak adına göre gruplu) -->
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4" Elevation="2" Style="min-height: 350px; max-height: 500px; overflow-y: auto;">
                        <MudText Typo="Typo.h6" Class="mb-2" Color="Color.Primary">Alan Listesi</MudText>
                        @if (!_sources.Any())
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                        }
                        else
                        {
                            @foreach (var source in _sources)
                            {
                                var sourceItems = _dropItems.Where(x => x.Field.SourceId == source.Id && x.DropZone.StartsWith("field-list")).ToList();
                                if (sourceItems.Any())
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1 fw-bold" Style="color: var(--brand-primary, #1A2B47);">@source.DisplayName</MudText>
                                    <MudDropZone T="DropItem" Identifier="@($"field-list-{source.Id}")" Class="d-flex flex-wrap gap-2 mb-2 pa-2 rounded" Style="background-color: rgba(0,0,0,0.03); min-height: 45px;" />
                                }
                            }
                        }
                    </MudPaper>
                </MudItem>

                <!-- Orta Panel: Drop Zone (Rapor Alanları) -->
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4 d-flex flex-column" Elevation="2" Style="min-height: 350px;">
                        <MudText Typo="Typo.h6" Class="mb-2" Color="Color.Primary">Rapor Alanları (Sürükleyip Bırakın)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Sol panelden istediğiniz alanları buraya sürükleyip sıralayabilirsiniz.
                        </MudText>
                        <MudDropZone T="DropItem" 
                                     Identifier="report-zone" 
                                     AllowReorder="true" 
                                     Class="flex-grow-1 border-2 border-dashed pa-4 rounded d-flex flex-wrap gap-2 align-content-start" 
                                     Style="min-height: 200px; background-color: rgba(26, 43, 71, 0.03); border-color: var(--brand-gold, #B89968) !important;" />
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </ChildContent>
        <ItemRenderer Context="item">
            @if (item.DropZone == "report-zone")
            {
                <MudChip T="string" 
                         Color="@(item.Field.Role == "measure" ? Color.Secondary : Color.Info)" 
                         Variant="Variant.Filled" 
                         Size="Size.Medium"
                         OnClose="@(() => RemoveFromReportZone(item))" 
                         Class="cursor-move my-1">
                    @item.Field.DisplayName @(item.Field.Role == "measure" ? $"({item.Field.DefaultAggregation ?? "sum"})" : "")
                </MudChip>
            }
            else
            {
                <MudChip T="string" 
                         Color="@(item.Field.Role == "measure" ? Color.Secondary : Color.Info)" 
                         Variant="Variant.Filled" 
                         Size="Size.Small"
                         Class="cursor-move my-1">
                    @item.Field.DisplayName @(item.Field.Role == "measure" ? $"({item.Field.DefaultAggregation ?? "sum"})" : "")
                </MudChip>
            }
        </ItemRenderer>
    </MudDropContainer>

    <!-- Butonun altında: Koşullu MudAlert + MudDataGrid -->
    @if (!string.IsNullOrEmpty(_activeAlertMessage) && _activeAlertSeverity.HasValue)
    {
        <MudAlert Severity="@_activeAlertSeverity.Value" Variant="Variant.Filled" Class="mt-4 mb-2" ShowCloseIcon="true" CloseIconClicked="@(() => _activeAlertMessage = null)">
            @_activeAlertMessage
        </MudAlert>
    }

    @if (_lastQueryResult != null && _lastQueryResult.Columns != null)
    {
        if (_selectedView == "KPI")
        {
            <LogoBI.Client.Components.KpiCard QueryResult="@_lastQueryResult" />
        }
        else
        {
            <MudPaper Class="pa-4 mt-4" Elevation="2">
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-3">Önizleme Sonuçları (@_lastQueryResult.Rows.Count Satır)</MudText>
                <MudDataGrid T="IReadOnlyList<object?>" Items="@_lastQueryResult.Rows" Dense="true" Hover="true" Striped="true" Bordered="true">
                    <Columns>
                        @for (int i = 0; i < _lastQueryResult.Columns.Count; i++)
                        {
                            int colIndex = i;
                            var colMeta = _lastQueryResult.Columns[i];
                            <TemplateColumn T="IReadOnlyList<object?>" Title="@colMeta.DisplayName">
                                <CellTemplate>
                                    @if (context.Item != null && context.Item.Count > colIndex)
                                    {
                                        @FormatCellValue(context.Item[colIndex])
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                        }
                    </Columns>
                </MudDataGrid>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private IReadOnlyList<ClientSourceInfo> _sources = Array.Empty<ClientSourceInfo>();
    private IReadOnlyList<ClientFieldInfo> _fields = Array.Empty<ClientFieldInfo>();
    private List<DropItem> _dropItems = new();

    private int _selectedAnchorId = 0;
    private bool _isLoading = false;

    private string? _activeAlertMessage = null;
    private Severity? _activeAlertSeverity = null;
    private ClientQueryResult? _lastQueryResult = null;

    private readonly JsonSerializerOptions _jsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private IReadOnlyList<CatalogFirmInfo> _catalogFirms = Array.Empty<CatalogFirmInfo>();
    private int _selectedFirmNr = 0;
    private int _selectedPeriodNr = 0;

    private IReadOnlyList<CatalogPeriodInfo> CurrentPeriods =>
        _catalogFirms.FirstOrDefault(f => f.FirmNr == _selectedFirmNr)?.Periods ?? Array.Empty<CatalogPeriodInfo>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var sourcesTask = Http.GetFromJsonAsync<List<ClientSourceInfo>>("api/metadata/sources", _jsonOptions);
            var fieldsTask = Http.GetFromJsonAsync<List<ClientFieldInfo>>("api/metadata/fields", _jsonOptions);
            var catalogTask = Http.GetFromJsonAsync<List<CatalogFirmInfo>>("api/catalog/firms-periods", _jsonOptions);

            await Task.WhenAll(sourcesTask, fieldsTask, catalogTask);

            var sources = await sourcesTask;
            var fields = await fieldsTask;
            var catalog = await catalogTask;

            if (sources != null) _sources = sources;
            if (fields != null)
            {
                _fields = fields;
                _dropItems = _fields.Select(f =>
                {
                    var sourceName = _sources.FirstOrDefault(s => s.Id == f.SourceId)?.DisplayName ?? "Diğer";
                    return new DropItem
                    {
                        Field = f,
                        SourceDisplayName = sourceName,
                        DropZone = $"field-list-{f.SourceId}"
                    };
                }).ToList();
            }
            if (catalog != null)
            {
                _catalogFirms = catalog;
                var defaultFirm = _catalogFirms.FirstOrDefault(f => f.FirmNr == 126);
                if (defaultFirm != null && defaultFirm.Periods.Any(p => p.PeriodNr == 1))
                {
                    _selectedFirmNr = 126;
                    _selectedPeriodNr = 1;
                }
                else if (_catalogFirms.Any())
                {
                    var firstFirm = _catalogFirms.First();
                    _selectedFirmNr = firstFirm.FirmNr;
                    if (firstFirm.Periods.Any())
                    {
                        _selectedPeriodNr = firstFirm.Periods.First().PeriodNr;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _activeAlertSeverity = Severity.Error;
            _activeAlertMessage = "Metadata yüklenirken bağlantı hatası oluştu: " + ex.Message;
        }
    }

    private string _selectedView = "Grid";

    private bool IsKpiAllowed
    {
        get
        {
            var reportItems = _dropItems.Where(x => x.DropZone == "report-zone").ToList();
            int measureCount = reportItems.Count(x => string.Equals(x.Field.Role, "measure", StringComparison.OrdinalIgnoreCase));
            int dimensionCount = reportItems.Count(x => !string.Equals(x.Field.Role, "measure", StringComparison.OrdinalIgnoreCase));
            return measureCount == 1 && dimensionCount == 0;
        }
    }

    private void OnViewChanged(string newView)
    {
        if (!string.IsNullOrEmpty(newView))
        {
            _selectedView = newView;
        }
    }

    private void EnsureValidView()
    {
        if (!IsKpiAllowed && _selectedView == "KPI")
        {
            _selectedView = "Grid";
        }
    }

    private void OnFirmChanged(int newFirmNr)
    {
        _selectedFirmNr = newFirmNr;
        _selectedPeriodNr = 0;
        var firm = _catalogFirms.FirstOrDefault(f => f.FirmNr == newFirmNr);
        if (firm != null && firm.Periods.Any())
        {
            _selectedPeriodNr = firm.Periods.First().PeriodNr;
        }
    }

    private void OnPeriodChanged(int newPeriodNr)
    {
        _selectedPeriodNr = newPeriodNr;
    }

    private void OnAnchorChanged(int newAnchorId)
    {
        _selectedAnchorId = newAnchorId;
        foreach (var item in _dropItems.Where(x => x.DropZone == "report-zone"))
        {
            item.DropZone = $"field-list-{item.Field.SourceId}";
        }
        _activeAlertMessage = null;
        _activeAlertSeverity = null;
        EnsureValidView();
    }

    private void OnItemDropped(MudItemDropInfo<DropItem> dropInfo)
    {
        if (dropInfo.Item == null) return;

        if (dropInfo.DropzoneIdentifier == "report-zone")
        {
            dropInfo.Item.DropZone = "report-zone";
        }
        else
        {
            dropInfo.Item.DropZone = $"field-list-{dropInfo.Item.Field.SourceId}";
        }
        EnsureValidView();
    }

    private void RemoveFromReportZone(DropItem item)
    {
        item.DropZone = $"field-list-{item.Field.SourceId}";
        EnsureValidView();
    }

    private async Task OnPreviewClicked()
    {
        if (_selectedAnchorId <= 0) return;
        var selectedItems = _dropItems.Where(x => x.DropZone == "report-zone").ToList();
        if (!selectedItems.Any()) return;

        _isLoading = true;
        try
        {
            var fieldIds = selectedItems.Select(x => x.Field.Id).ToList();
            var reportDef = new ReportDefinition
            {
                AnchorSourceId = _selectedAnchorId,
                FieldIds = fieldIds
            };

            var request = new ClientReportPreviewRequest(
                ReportDefinition: reportDef,
                FirmaNo: _selectedFirmNr,
                DonemNo: _selectedPeriodNr
            );
            using var response = await Http.PostAsJsonAsync("api/report/preview", request, _jsonOptions);

            if (response.IsSuccessStatusCode)
            {
                _activeAlertMessage = null;
                _activeAlertSeverity = null;
                _lastQueryResult = await response.Content.ReadFromJsonAsync<ClientQueryResult>(_jsonOptions);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.UnprocessableEntity)
            {
                var error = await response.Content.ReadFromJsonAsync<ClientApiErrorResponse>(_jsonOptions);
                _activeAlertSeverity = Severity.Warning;
                _activeAlertMessage = error?.Message ?? "Sorgu işlenemedi.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var error = await response.Content.ReadFromJsonAsync<ClientApiErrorResponse>(_jsonOptions);
                _activeAlertSeverity = Severity.Warning;
                _activeAlertMessage = error?.Message ?? "Geçersiz rapor tanımı.";
            }
            else
            {
                _activeAlertSeverity = Severity.Error;
                _activeAlertMessage = "Bağlantı hatası, tekrar deneyin";
            }
        }
        catch (Exception)
        {
            _activeAlertSeverity = Severity.Error;
            _activeAlertMessage = "Bağlantı hatası, tekrar deneyin";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string FormatCellValue(object? cellValue)
    {
        if (cellValue == null) return "";
        if (cellValue is JsonElement jsonElement)
        {
            return jsonElement.ValueKind switch
            {
                JsonValueKind.Null or JsonValueKind.Undefined => "",
                JsonValueKind.String => jsonElement.GetString() ?? "",
                JsonValueKind.Number => jsonElement.GetRawText(),
                JsonValueKind.True => "True",
                JsonValueKind.False => "False",
                _ => jsonElement.ToString()
            };
        }
        return cellValue.ToString() ?? "";
    }
}